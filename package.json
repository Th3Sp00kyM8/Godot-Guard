{
  "name": "godot-guard",
  "version": "0.1.3",
  "description": "A local health checker for AI-assisted Godot projects.",
  "type": "module",
  "author": "Th3Sp00kyM8",
  "homepage": "https://github.com/Th3Sp00kyM8/Godot-Guard#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Th3Sp00kyM8/Godot-Guard.git"
  },
  "bugs": {
    "url": "https://github.com/Th3Sp00kyM8/Godot-Guard/issues"
  },
  "bin": {
